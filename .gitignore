# Python caches
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# macOS / editor noise
.DS_Store
.AppleDouble
.LSOverride
._*
.vscode/
.idea/
*.swp
*.swo

# Local environments
.env
.venv/
venv/
conda-meta/
.mamba/
*.log

# PyMACS run folders and large/generated MD outputs
RUNS/
runs/
run*/
*_run*/
Analysis_Results/
NETWORX/
RESIDUE_Contact_Distance/
RESIDUE_Pies/

# GROMACS generated outputs
*.tpr
*.xtc
*.trr
*.edr
*.cpt
*_prev.cpt
*.xvg
*.gro
*.ndx
*.top
